# The OpenRouter API key is not configured here.
# Open WebUI sends it as Authorization: Bearer <key>, and the gateway forwards
# that same key to OpenRouter.

# The OpenRouter model is not configured here.
# Open WebUI sends the selected model id in the request body as "model".

# Optional: comma-separated modalities sent to OpenRouter for image generation.
OPENROUTER_MODALITIES=image,text

# Optional: return b64_json by default. Set to url to return OpenRouter data URLs.
DEFAULT_RESPONSE_FORMAT=b64_json

# Optional: headers recommended by OpenRouter for app attribution.
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=openrouter-image-gateway

# Optional: network and request limits.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_SECONDS=120
MAX_IMAGES_PER_REQUEST=4
HOST_PORT=8000
